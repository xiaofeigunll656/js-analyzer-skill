{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/js-analyzer-skill/analysis-ir.schema.json",
  "title": "JS Analyzer Intermediate Representation",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "inventory",
    "modules",
    "features",
    "apis",
    "crypto",
    "configs",
    "accounts",
    "externalAssets",
    "chunkDiscovery",
    "sourceMapDiscovery",
    "supplementDiscovery",
    "callGraph",
    "diagrams",
    "developerSignals",
    "operationsSignals",
    "thirdPartyServices",
    "evidence",
    "uncertainties"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "project": { "type": "object" },
    "inventory": { "type": "object" },
    "modules": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "features": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "apis": { "type": "array", "items": { "$ref": "#/$defs/api" } },
    "crypto": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "configs": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "accounts": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "externalAssets": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "chunkDiscovery": {
      "type": "object",
      "properties": {
        "publicPaths": { "type": "array" },
        "candidates": { "type": "array" },
        "downloaded": { "type": "array" },
        "needsBaseUrl": { "type": "array" }
      },
      "additionalProperties": true
    },
    "sourceMapDiscovery": {
      "type": "object",
      "properties": {
        "candidates": { "type": "array" },
        "downloaded": { "type": "array" },
        "needsBaseUrl": { "type": "array" }
      },
      "additionalProperties": true
    },
    "supplementDiscovery": {
      "type": "object",
      "properties": {
        "candidates": { "type": "array" },
        "downloaded": { "type": "array" },
        "localCacheSearches": { "type": "array" },
        "missingPlugins": { "type": "array" },
        "h5Entries": { "type": "array" },
        "nestedStaticAssets": { "type": "array" },
        "sourceMapCandidates": { "type": "array" },
        "foundLocalPackages": { "type": "array" },
        "downloadable": { "type": "array" }
      },
      "additionalProperties": true
    },
    "callGraph": { "type": "array", "items": { "type": "object" } },
    "callGraphStats": {
      "type": "object",
      "properties": {
        "rawEdges": { "type": "integer", "minimum": 0 },
        "dedupedEdges": { "type": "integer", "minimum": 0 },
        "retainedEdges": { "type": "integer", "minimum": 0 },
        "limit": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "diagrams": { "type": "array", "items": { "type": "object" } },
    "developerSignals": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "operationsSignals": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "thirdPartyServices": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "uncertainties": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
    "analysisState": { "type": "object" }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["id", "type", "name"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "value": {},
        "category": { "type": "string" },
        "description": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "relatedIds": { "type": "array", "items": { "type": "string" } },
        "evidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "api": {
      "type": "object",
      "required": ["id", "method", "url"],
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "featureId": { "type": "string" },
        "name": { "type": "string" },
        "method": { "type": "string" },
        "url": { "type": "string" },
        "baseUrl": { "type": "string" },
        "path": { "type": "string" },
        "headers": { "type": "object" },
        "query": { "type": "object" },
        "body": {},
        "auth": { "type": "object" },
        "contentType": { "type": "string" },
        "requestMock": {},
        "responseMock": {},
        "cryptoIds": { "type": "array", "items": { "type": "string" } },
        "evidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "required": ["id", "file", "line", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 },
        "snippet": { "type": "string" },
        "method": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    }
  }
}
